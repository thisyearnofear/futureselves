{
  "expo": {
    "name": "Future Selves",
    "slug": "future-selves",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "orientation": "portrait",
    "icon": "../../assets/images/futureself-icon.png",
    "scheme": "futureself",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "../../assets/images/futureself-icon.png",
        "backgroundColor": "#080A17"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "../../assets/images/futureself-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "../../assets/images/futureself-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#080A17"
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      [
        "expo-audio",
        {
          "enableBackgroundPlayback": true,
          "enableBackgroundRecording": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "displayName": "Future Selves"
  }
}
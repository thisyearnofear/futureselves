#!/bin/sh
set -eu

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  exit 0
fi

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$staged_files" ]; then
  exit 0
fi

blocked_paths='(^|/)(\.env|\.env\.[^/]+)$|(^|/).*\.(pem|p12|p8|key|jks|mobileprovision)$'
allowed_env_examples='(^|/)(\.env\.example|\.env\.sample|\.env\.template)$'
secret_patterns='-----BEGIN (RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----|AKIA[0-9A-Z]{16}|ghp_[A-Za-z0-9]{36,}|github_pat_[A-Za-z0-9_]{20,}|sk-[A-Za-z0-9]{20,}|AIza[0-9A-Za-z_-]{35}|xox[baprs]-[A-Za-z0-9-]{10,}|(anthropic|elevenlabs|openai|github|slack|stripe|convex)[A-Za-z0-9_ -]{0,20}(api)?[ _-]?key[[:space:]]*[:=][[:space:]]*[A-Za-z0-9_-]{12,}|(secret|token|password)[[:space:]]*[:=][[:space:]]*[A-Za-z0-9_-]{16,}'

has_failures=0

while IFS= read -r path; do
  [ -n "$path" ] || continue

  if printf '%s\n' "$path" | grep -Eq -- "$blocked_paths"; then
    if ! printf '%s\n' "$path" | grep -Eq -- "$allowed_env_examples"; then
      echo "pre-commit: blocked sensitive file path: $path" >&2
      has_failures=1
    fi
  fi

  if git cat-file -e ":$path" 2>/dev/null; then
    if git show ":$path" | grep -Eiq -- "$secret_patterns"; then
      echo "pre-commit: potential secret detected in staged file: $path" >&2
      has_failures=1
    fi
  fi

done <<EOF
$staged_files
EOF

if [ "$has_failures" -ne 0 ]; then
  cat >&2 <<'EOF'
pre-commit: commit blocked to protect secrets.

What to do:
- remove the secret from the staged file
- move real values into an untracked `.env`
- keep only placeholders in `.env.example`
- restage with `git add ...` after cleaning
EOF
  exit 1
fi

exit 0

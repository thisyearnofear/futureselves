{
  "name": "future-selves",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:backend": "turbo run dev --filter=@bloom/backend",
    "dev:mobile": "turbo run dev --filter=@bloom/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@rolldown/binding-linux-arm64-gnu": "^1.0.0-rc.17",
    "convex": "^1.37.0",
    "turbo": "^2.0.12"
  },
  "packageManager": "bun@1.3.6",
  "dependencies": {
    "lightningcss": "^1.32.0"
  }
}
